{
  "name": "indie-swift-compiler-direct-embedded-pipeline",
  "goal": "Swift source を完全抽出した parser/AST/Sema/SILGen/SIL/SILOptimizer/IRGen に流し LLVM へ渡す",
  "stageOrder": [
    "swift",
    "parser",
    "ast",
    "sema",
    "silgen",
    "sil",
    "sil-optimizer-mandatory",
    "sil-optimizer-performance",
    "irgen",
    "llvm"
  ],
  "stages": {
    "swift": {
      "kind": "source",
      "entrypoints": [
        "MiniCompiler.compileSource",
        "MiniSwiftCompilerBridge.compileToIR"
      ],
      "dependsOn": []
    },
    "parser": {
      "kind": "frontend-parser",
      "entrypoints": [
        "swift_parser_embedded_parse",
        "swift_parser_extract_parse"
      ],
      "dependsOn": [
        "swift"
      ]
    },
    "ast": {
      "kind": "frontend-ast",
      "entrypoints": [
        "swift_ast_embedded_build_module",
        "swift_ast_extract_build_module"
      ],
      "dependsOn": [
        "parser"
      ]
    },
    "sema": {
      "kind": "frontend-sema",
      "entrypoints": [
        "swift_sema_embedded_typecheck",
        "swift_sema_extract_typecheck"
      ],
      "dependsOn": [
        "ast"
      ]
    },
    "silgen": {
      "kind": "frontend-silgen",
      "entrypoints": [
        "swift_silgen_embedded_emit_raw_sil",
        "swift_silgen_extract_emit_raw_sil"
      ],
      "dependsOn": [
        "sema"
      ]
    },
    "sil": {
      "kind": "middle-end-sil",
      "entrypoints": [
        "swift_sil_embedded_materialize_module",
        "swift_irgen_adapter_emit_sil"
      ],
      "dependsOn": [
        "silgen"
      ]
    },
    "sil-optimizer-mandatory": {
      "kind": "middle-end-mandatory",
      "entrypoints": [
        "swift_sil_optimizer_adapter_run_mandatory",
        "swift_sil_optimizer_embedded_run_mandatory"
      ],
      "dependsOn": [
        "sil"
      ]
    },
    "sil-optimizer-performance": {
      "kind": "middle-end-performance",
      "entrypoints": [
        "swift_sil_optimizer_adapter_run_performance",
        "swift_sil_optimizer_embedded_run_performance"
      ],
      "dependsOn": [
        "sil-optimizer-mandatory"
      ]
    },
    "irgen": {
      "kind": "backend-irgen",
      "entrypoints": [
        "swift_irgen_adapter_emit_ir_from_sil",
        "swift_irgen_embedded_emit_ir_from_sil"
      ],
      "dependsOn": [
        "sil-optimizer-performance"
      ]
    },
    "llvm": {
      "kind": "backend-llvm",
      "entrypoints": [
        "llvm_embedded_optimize_module",
        "llvm_embedded_emit_object"
      ],
      "dependsOn": [
        "irgen"
      ]
    }
  },
  "embeddedArtifacts": {
    "parserExtract": "Vendor/SwiftFrontendExtract/include/swift/Parse",
    "astExtract": "Vendor/SwiftFrontendExtract/include/swift/AST",
    "semaExtract": "Vendor/SwiftFrontendExtract/lib/Sema",
    "silgenExtract": "Vendor/SwiftFrontendExtract/lib/SILGen",
    "silExtract": "Vendor/SwiftFrontendExtract/lib/SIL",
    "silOptimizerAdapter": "libSwiftSILOptimizer.a",
    "irgenExtract": "Vendor/SwiftFrontendExtract/lib/IRGen",
    "clangXCFramework": "Clang.xcframework",
    "llvmXCFramework": "LLVM.xcframework"
  },
  "dependencyProfile": {
    "keepMinimal": [
      "swift",
      "llvm-project",
      "clang",
      "cmark",
      "swift-syntax",
      "swift-llvm-bindings"
    ],
    "avoid": [
      "swift-driver",
      "swift-package-manager",
      "sourcekit-lsp",
      "swift-docc",
      "swift-format",
      "swift-stress-tester"
    ]
  }
}
