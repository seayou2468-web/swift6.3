{
  "name": "swift-full-compat-lite",
  "goal": "Swift言語互換性を優先しつつ、parser/AST/Sema/SILGen/SIL/SILOptimizer/IRGen を直接内蔵して依存とビルド負荷を最小化する",
  "backend": {
    "primary": "direct-embedded-extract",
    "fallback": "llvm-clang-xcframework"
  },
  "enable": [
    "swift",
    "llvm-project",
    "clang",
    "cmark",
    "swift-syntax",
    "swift-llvm-bindings",
    "embedded-parser-ast-sema-silgen-sil-irgen-siloptim"
  ],
  "disable": [
    "swift-package-manager",
    "swift-driver",
    "swift-macro-system",
    "indexing",
    "ide-support",
    "lldb",
    "sourcekit-lsp",
    "swift-docc",
    "swift-format",
    "swift-stress-tester",
    "swift-sdk-generator"
  ]
}
